# ─── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_DB=rehabyou
POSTGRES_USER=rehabyou
POSTGRES_PASSWORD=changeme

# ─── Backend ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://rehabyou:changeme@db:5432/rehabyou
SECRET_KEY=your-secret-key-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=30
CORS_ORIGINS=["https://app.rehabyou.site","http://localhost:3000","http://localhost:5173"]

# ─── Yandex Object Storage (S3) ─────────────────────────────────
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=rehabyou-storage
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
