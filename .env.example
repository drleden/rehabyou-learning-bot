# ─── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_DB=rehabyou
POSTGRES_USER=rehabyou
POSTGRES_PASSWORD=changeme

# ─── Backend ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://rehabyou:changeme@db:5432/rehabyou
SECRET_KEY=your-secret-key-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=30
CORS_ORIGINS=["https://app.rehabyou.site","http://localhost:3000","http://localhost:5173"]

# ─── Academy Bot (Telegram) ──────────────────────────────────────
ACADEMY_BOT_TOKEN=your_bot_token
WEBAPP_URL=https://app.rehabyou.site
SUPERADMIN_PHONE=+79852977062
SUPERADMIN_PASSWORD=your_password
BOT_NOTIFY_URL=http://academy-bot:8080/notify
